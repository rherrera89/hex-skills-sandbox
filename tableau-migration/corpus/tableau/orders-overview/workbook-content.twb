            <column datatype='string' name='[Customer Value Tier]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 5000 THEN &quot;Platinum&quot; ELSEIF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 2000 THEN &quot;Gold&quot; ELSEIF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 500 THEN &quot;Silver&quot; ELSE &quot;Bronze&quot; END' />
            </column>
            <column datatype='real' name='[Gross Margin Pct]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IIF(SUM([33b6c718-9b55-3dc0-9698-d1d57fac0f90]) != 0, SUM([801a2d74-680d-3a22-b61d-c4cb64ea73b4]) / SUM([33b6c718-9b55-3dc0-9698-d1d57fac0f90]), 0)' />
            </column>

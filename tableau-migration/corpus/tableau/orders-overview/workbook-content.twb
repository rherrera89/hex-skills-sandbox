      <column datatype='string' name='[Customer Value Tier]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 5000 THEN &quot;Platinum&quot; ELSEIF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 2000 THEN &quot;Gold&quot; ELSEIF [06db681d-04be-3a38-b324-85dc4732a408] &gt;= 500 THEN &quot;Silver&quot; ELSE &quot;Bronze&quot; END' />
      </column>
      <column datatype='real' name='[Gross Margin Pct]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF(SUM([33b6c718-9b55-3dc0-9698-d1d57fac0f90]) != 0, SUM([801a2d74-680d-3a22-b61d-c4cb64ea73b4]) / SUM([33b6c718-9b55-3dc0-9698-d1d57fac0f90]), 0)' />
      </column>
      <column datatype='real' name='[Promo ROI]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([20ddaf1b-c665-351e-8aa6-f590dc70321a]) - SUM([1cf2a336-56c9-3e33-912c-56ab8b2d21d2])) / IIF(SUM([1cf2a336-56c9-3e33-912c-56ab8b2d21d2]) != 0, SUM([1cf2a336-56c9-3e33-912c-56ab8b2d21d2]), 1)' />
      </column>
      <column datatype='real' name='[Return Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([d3b60b0e-f547-3d2c-8602-5d077eb3151a]) / COUNT([7b7dc9c3-09e2-3bb1-ad44-754f9c95f56a])' />
      </column>
      <column datatype='real' name='[Revenue Per Order]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([20ddaf1b-c665-351e-8aa6-f590dc70321a]) / COUNTD([7b7dc9c3-09e2-3bb1-ad44-754f9c95f56a])' />
      </column>
      <column datatype='string' name='[Ship Speed Category]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [c7281f06-2028-3164-be3d-25be6d085a5e] &lt;= 2 THEN &quot;Express (1-2 days)&quot; ELSEIF [c7281f06-2028-3164-be3d-25be6d085a5e] &lt;= 5 THEN &quot;Standard (3-5 days)&quot; ELSEIF [c7281f06-2028-3164-be3d-25be6d085a5e] &lt;= 10 THEN &quot;Economy (6-10 days)&quot; ELSE &quot;Slow (10+ days)&quot; END' />
      </column>
      <column datatype='real' name='[YTD Revenue]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [f39416df-a452-37ef-9bdb-25f1314f2d11] : SUM([20ddaf1b-c665-351e-8aa6-f590dc70321a])}' />
      </column>

# Tableau Cloud connection — copy this file to `tableau.env` and fill in.
# `tableau.env` is gitignored; never commit real values.

# Base URL of your Tableau Cloud pod (no trailing slash).
# Find it in your browser's address bar when logged into Tableau Cloud, e.g.:
#   https://10ax.online.tableau.com
#   https://prod-uk-a.online.tableau.com
TABLEAU_SERVER=https://10ax.online.tableau.com

# Site content URL — the site name that appears in the URL after /site/.
# e.g. in https://10ax.online.tableau.com/#/site/mycompany/... the value is "mycompany"
TABLEAU_SITE=mycompany

# Personal Access Token (recommended auth). Create one in Tableau Cloud:
#   Account Settings -> Personal Access Tokens -> New Token
# Paste the token NAME and the SECRET it shows you (secret is shown only once).
TABLEAU_PAT_NAME=my-token-name
TABLEAU_PAT_SECRET=paste-the-long-secret-here
